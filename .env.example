# App Configuration
NEXT_PUBLIC_APP_NAME=NaviDash
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# Default bookmarks data
NEXT_PUBLIC_DEFAULT_BOOKMARKS=[]

# Demo Mode (true/false)
# If true, data persistence is disabled (for Vercel/demo deployment)
NEXT_PUBLIC_DEMO_MODE=false

# Weather
# Client-side weather widgets read this key directly.
NEXT_PUBLIC_QWEATHER_API_KEY=
# Optional custom QWeather-compatible host, e.g. api.example.com
NEXT_PUBLIC_QWEATHER_API_HOST=
# Optional auth mode: apikey or jwt
NEXT_PUBLIC_QWEATHER_AUTH_TYPE=apikey
